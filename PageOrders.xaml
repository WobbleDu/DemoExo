<Window x:Class="Demex3.PageOrders"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demex3"
        mc:Ignorable="d"
        Title="Заказы" Height="600" Width="900">
    <Grid>
        <ListBox x:Name="ListBoxOrders" Margin="0,50,0,50" HorizontalContentAlignment="Stretch" MouseUp="click_EditOrder">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="2"> 
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="1" Margin="10,5,5,5">
                                <StackPanel Margin="5">
                                    <TextBlock>
                                        <Run Text="Артикул заказа: " FontWeight="Bold"/>
                                        <Run Text="{Binding ID_order}"/>
                                    </TextBlock>

                                    <TextBlock>
                                        <Run Text="Статус заказа: "/>
                                        <Run Text="{Binding C_statuses.name}"/>
                                    </TextBlock>

                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Адрес пункта выдачи: "/>
                                        <Run Text="{Binding C_PVZ.info}"/>
                                    </TextBlock>

                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Дата заказа: "/>
                                        <Run Text="{Binding date_ordered}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="5" HorizontalAlignment="Right" BorderBrush="Black" BorderThickness="2">
                                <StackPanel Margin="5" VerticalAlignment="Center">
                                    <TextBlock Text="Дата доставки" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding date_recieved}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button x:Name="click_Back" Content="Назад" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="60" Height="20" Margin="0,0,20,20" Click="click_Back_Click"/>
        <Button x:Name="bt_DeleteOrder" Content="Удалить заказ" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="20" Width="120" Margin="20,0,0,20" Click="click_DeleteOrder"/>
        <Button x:Name="bt_AddOrder" Content="Добавить заказ" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="120" Height="20" Margin="180,0,0,20" Click="click_AddOrder"/>

    </Grid>
</Window>
